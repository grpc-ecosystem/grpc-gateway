        [grpc.gateway.protoc_gen_openapiv3.options.openapiv3_field]: {
          description: "Item name"
        }
      }
    }
    field: {
      name: "status"
      number: 3
      label: LABEL_OPTIONAL
      type: TYPE_ENUM
      type_name: ".comprehensive.Status"
      json_name: "status"
    }
    field: {
      name: "created_at"
      number: 4
      label: LABEL_OPTIONAL
      type: TYPE_STRING
      json_name: "createdAt"
      options: {
        [grpc.gateway.protoc_gen_openapiv3.options.openapiv3_field]: {
          description: "Creation timestamp"
          read_only: true
        }
      }
    }
  }

  message_type: {
    name: "ListItemsRequest"
    field: {
      name: "page_size"
      number: 1
