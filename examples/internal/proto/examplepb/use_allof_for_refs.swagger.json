        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/examplepbGetExampleResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "exampleId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "UseAllOfForRefsService"
        ]
      }
    }
  },
