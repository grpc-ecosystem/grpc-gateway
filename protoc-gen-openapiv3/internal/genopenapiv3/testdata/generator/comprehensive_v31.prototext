    field: {
      name: "item"
      number: 2
      label: LABEL_OPTIONAL
      type: TYPE_MESSAGE
      type_name: ".comprehensive.Item"
      json_name: "item"
    }
  }

  message_type: {
    name: "PatchItemRequest"
    field: {
      name: "item_id"
      number: 1
      label: LABEL_OPTIONAL
      type: TYPE_STRING
      json_name: "itemId"
    }
    field: {
      name: "item"
      number: 2
      label: LABEL_OPTIONAL
      type: TYPE_MESSAGE
      type_name: ".comprehensive.Item"
      json_name: "item"
    }
    field: {
      name: "update_mask"
      number: 3
      label: LABEL_OPTIONAL
      type: TYPE_STRING
      json_name: "updateMask"
    }
  }

  message_type: {
    name: "DeleteItemRequest"
    field: {
      name: "item_id"
