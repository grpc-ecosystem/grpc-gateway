load("@io_bazel_rules_go//go:def.bzl", "go_library")

go_library(
    name = "client",
    srcs = ["a_bit_of_everything_client.go"],
    importpath = "github.com/grpc-ecosystem/grpc-gateway/v2/examples/internal/clients/abe/client",
    visibility = ["//examples:__subpackages__"],
    deps = [
        "//examples/internal/clients/abe/client/a_bit_of_everything",
        "//examples/internal/clients/abe/client/camel_case_service_name",
        "//examples/internal/clients/abe/client/echo_rpc",
        "//examples/internal/clients/abe/client/snake_enum_service",
        "@com_github_go_openapi_runtime//:runtime",
        "@com_github_go_openapi_runtime//client",
        "@com_github_go_openapi_strfmt//:strfmt",
    ],
)

alias(
    name = "go_default_library",
    actual = ":client",
    visibility = ["//examples:__subpackages__"],
)
