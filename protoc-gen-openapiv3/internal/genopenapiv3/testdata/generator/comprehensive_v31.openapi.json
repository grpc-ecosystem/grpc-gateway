                                    "$ref": "#/components/schemas/google.rpc.Status"
                                }
                            }
                        }
                    }
                }
            },
            "patch": {
                "tags": [
                    "ItemService"
                ],
                "summary": "Partial update an item",
                "description": "Partially updates an item using field mask.",
                "operationId": "ItemService_PatchItem",
                "parameters": [
                    {
                        "name": "item_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/comprehensivePatchItemRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "A successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/comprehensiveItem"
                                }
                            }
                        }
