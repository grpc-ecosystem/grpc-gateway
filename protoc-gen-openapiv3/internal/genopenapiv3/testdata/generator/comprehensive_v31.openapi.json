    "paths": {
        "/v1/items": {
            "get": {
                "tags": [
                    "ItemService"
                ],
                "summary": "List all items",
                "description": "Returns a paginated list of items.",
                "operationId": "ItemService_ListItems",
                "parameters": [
                    {
                        "name": "page_size",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "format": "int32"
                        }
                    },
                    {
                        "name": "page_token",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "A successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/comprehensiveListItemsResponse"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/google.rpc.Status"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "ItemService"
                ],
                "summary": "Create a new item",
                "description": "Creates a new item and returns the created item.",
                "operationId": "ItemService_CreateItem",
                "requestBody": {
                    "description": "Item to create",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/comprehensiveCreateItemRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "A successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/comprehensiveItem"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "An unexpected error response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/google.rpc.Status"
                                }
                            }
                        }
                    }
                }
            }
        },
