        "title": "Comprehensive OpenAPI v3.1.0 Test API",
        "summary": "Tests all OpenAPI 3.1.0 features",
        "description": "Comprehensive test covering all supported features including schemas, validation, composition, and visibility.",
        "termsOfService": "https://example.com/terms",
        "contact": {
            "name": "API Support",
            "url": "https://example.com/support",
            "email": "support@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "identifier": "Apache-2.0"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://api.example.com/{version}",
            "description": "Production server",
            "variables": {
                "version": {
                    "enum": [
                        "v1",
                        "v2"
                    ],
                    "default": "v1",
                    "description": "API version"
                }
            }
        },
        {
            "url": "https://staging.example.com/v1",
