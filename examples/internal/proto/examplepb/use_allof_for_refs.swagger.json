  "tags": [
    {
      "name": "UseAllOfForRefsService",
      "description": "UseAllOfForRefsService demonstrates the use_allof_for_refs option.\n\nWhen that option is enabled, a field that is a message reference normally\nrenders as a bare \"$ref\". Per the JSON Reference syntax any sibling members\nof a \"$ref\" are ignored, so the field is instead wrapped in an \"allOf\" to\npreserve its title, description and OpenAPI extensions next to the ref."
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
